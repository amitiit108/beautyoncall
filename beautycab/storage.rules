rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /artists/{artistId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == artistId;
    }

    match /bookings/{bookingId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
