rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read, update: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn();
      allow read, write: if isAdmin();
    }

    match /artists/{artistId} {
      allow read: if true;
      allow create, update: if signedIn() && request.auth.uid == artistId;
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow create: if signedIn();
      allow read, update: if signedIn();
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read, write: if signedIn();
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read, update: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn();
      allow write: if isAdmin();
    }

    match /admin_settings/{settingId} {
      allow read, write: if isAdmin();
    }
  }
}
